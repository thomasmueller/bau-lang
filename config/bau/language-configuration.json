{
  "comments": {
    "lineComment": "#",
    "blockComment": ["##", "##"]
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] }
  ],
  "autoCloseBefore": ".,<>=]) \n",
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["'", "'"]
  ],
  "folding": {
    "offSide": true
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "onEnterRules": [
		{
			"beforeText": "^\\s*(?:if|elif|else|for|loop|switch|case|catch|fun|type|enum|trait|macro|import|and|or|not|\\.|\\(|\\,).*?\\s*$",
			"action": { "indent": "indent" }
		},
		{
			"beforeText": "^\\s*(?:return|throw).*?\\s*$",
			"action": { "indent": "outdent" }
		},
		{
			"beforeText": "^\\s*(?:break|continue)\\s*$",
			"action": { "indent": "outdent" }
		}
  ]
}
