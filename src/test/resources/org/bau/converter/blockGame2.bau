import org.bau.graphics.SDL3
    SDL
    start
    event
    eventType
    keyCode
import org.bau.os.Sleep
import org.bau.DateTime
import org.bau.Math
import org.bau.String
import org.bau.Utils
import org.bau.Env
    exit

fun main()
    Utils.setRandomSeed(DateTime.getNanoTime())
    sdl : SDL3.open(640, 768)
    if not sdl
        return
    loop
        score = 0
        rotation = 0
        position = WIDTH + WIDTH / 2 - 1
        running = 1
        blockType = 1
        for i := until(WIDTH * HEIGHT)
            FIELD[i] = 0
        for y := until(HEIGHT)
            FIELD[WIDTH * y] = 1
            FIELD[WIDTH - 1 + WIDTH * y] = 1
        for x := until(WIDTH)
            FIELD[x + WIDTH * (HEIGHT - 1)] = 1
        refreshScreen(sdl)
        loop
            updateBlock(0)
            tick := 16
            if score < 8
                tick += 8 - score
            loop tick > 0 and running
                tick -= 1
                Sleep.sleep(14)
                e : sdl.pollEvent()
                continue e.type = eventType.none
                break e.type = eventType.quit
                tempRot := rotation
                tempPos := position
                if e.type = eventType.key
                    switch e.key
                    case keyCode.escape
                        sdl.close()
                        Env.exit(0)
                        break
                    case keyCode.left
                        tempPos -= 1
                    case keyCode.right
                        tempPos += 1
                    case ord(' '), keyCode.up
                        tempRot = rotated[rotation] - ord('A')
                    case keyCode.down
                        running = 0
                    else
                        println('some other key')
                if canPlace(tempPos, tempRot)
                    position = tempPos
                    rotation = tempRot
                    updateBlock(1)
                    refreshScreen(sdl)
                    updateBlock(0)
            if canPlace(position + WIDTH, rotation)
                position += WIDTH
                updateBlock(1)
                refreshScreen(sdl)
                continue
            updateBlock(1)
            i := HEIGHT - 2
            loop i > 0
                found := 1
                for j := until(WIDTH)
                    if FIELD[i * WIDTH + j] = 0
                        found = 0
                        break
                if found
                    i += 1
                    score += 1
                    if score > highScore
                        highScore = score
                    k := i * WIDTH - WIDTH
                    loop k >= 0
                        FIELD[k + WIDTH] = FIELD[k]
                        k -= 1
                i -= 1
            refreshScreen(sdl)
            rotation = Utils.random(7)
            blockType = rotation + 1
            break position < WIDTH * 2
            position = WIDTH + WIDTH / 2 - 1
            running = 1

fun updateBlock(draw int)
    for y := until(4)
        for x := until(4)
            c : shapes[y * 21 * 6 + rotation * 6 + x]
            continue c <> ord('X')
            offset : y * WIDTH + x
            FIELD[position + offset] = (1 + blockType) * draw

fun canPlace(pos int, rot int) int
    for y := until(4)
        for x := until(4)
            c : shapes[y * 21 * 6 + rot * 6 + x]
            continue c <> ord('X')
            offset : y * WIDTH + x
            if FIELD[pos + offset]
                return 0
    return 1

fun refreshScreen(sdl SDL)
    sdl.color(0, 0, 0, 255)
    sdl.fillRect(512, 64, 96, 8 * 32)
    sdl.color(255, 255, 255, 255)
    sdl.debugText(512, 4 * 32, 'Score')
    sdl.debugText(512, 5 * 32, Int.intToString(score))
    sdl.debugText(512, 8 * 32, 'Highscore')
    sdl.debugText(512, 9 * 32, Int.intToString(highScore))
    for y := until(HEIGHT)
        for x := until(WIDTH)
            c := FIELD[x + WIDTH * y]
            r := 0
            g := 0
            b := 0
            switch c
            case 0
                r = 0
            case 1
                r = 64
                g = 64
                b = 64
            case 2
                r = 255
            case 3
                g = 255
            case 4
                b = 255
            case 5
                r = 255
                g = 255
            case 6
                g = 255
                b = 255
            case 7
                r = 255
                b = 255
            case 8
                r = 128
                g = 255
            case 9
                g = 128
                b = 255
            case 10
                b = 255
            sdl.color(r, g, b, 255)
            sdl.fillRect(x * 32, y * 32, 31, 31)
            if c
                c2 : i8[1]
                c2[0] = ord('0') + c - 1
    sdl.draw()

WIDTH : 14
HEIGHT : 24
score, highScore, position, rotation, running, blockType := 0
FIELD : i8[WIDTH * HEIGHT]
