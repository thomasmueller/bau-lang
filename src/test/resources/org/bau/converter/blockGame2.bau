import org.bau.graphics.SDL3
    SDL
    start
    event
    eventType
    keyCode
import org.bau.os.Sleep
import org.bau.DateTime
import org.bau.Math
import org.bau.String
import org.bau.Utils
import org.bau.Env
    exit

fun main()
    Utils.setRandomSeed(DateTime.getNanoTime())
    sdl : SDL3.open()
    if not sdl
        return
    loop
        score = 0
        rotation = 0
        position = WIDTH + WIDTH / 2 - 1
        running = 1
        blockType = 1
        for i := until(WIDTH * HEIGHT)
            FIELD[i] = 0
        for y := until(HEIGHT)
            FIELD[WIDTH * y] = 1
            FIELD[WIDTH - 1 + WIDTH * y] = 1
        for x := until(WIDTH)
            FIELD[x + WIDTH * (HEIGHT - 1)] = 1
        refreshScreen(sdl)
        loop
            updateBlock(0)
            tick := 16
            loop tick > 0 and running
                tick -= 1
                Sleep.sleep(14)
                e : sdl.pollEvent()
                continue e.type = eventType.none
                break e.type = eventType.quit
                tempRot := rotation
                tempPos := position
                if e.type = eventType.key
                    switch e.key
                    case keyCode.escape
                        sdl.close()
                        Env.exit(0)
                        break
                    case keyCode.left
                        tempPos -= 1
                    case keyCode.right
                        tempPos += 1
                    case ord(' '), keyCode.up
                        tempRot = rotated[rotation] - ord('A')
                    case keyCode.down
                        running = 0
                    else
                        println('some other key')
                if canPlace(tempPos, tempRot)
                    position = tempPos
                    rotation = tempRot
                    updateBlock(1)
                    refreshScreen(sdl)
                    updateBlock(0)
            if canPlace(position + WIDTH, rotation)
                position += WIDTH
                updateBlock(1)
                refreshScreen(sdl)
                continue
            updateBlock(1)
            i := HEIGHT - 2
            loop i > 0
                found := 1
                for j := until(WIDTH)
                    if FIELD[i * WIDTH + j] = 0
                        found = 0
                        break
                if found
                    i += 1
                    score += 1
                    if score > highScore
                        highScore = score
                    k := i * WIDTH - WIDTH
                    loop k >= 0
                        FIELD[k + WIDTH] = FIELD[k]
                        k -= 1
                i -= 1
            refreshScreen(sdl)
            rotation = Utils.random(7)
            blockType = rotation + 1
            break position < WIDTH * 2
            position = WIDTH + WIDTH / 2 - 1
            running = 1

fun updateBlock(draw int)
    for y := until(4)
        for x := until(4)
            c : shapes[y * 21 * 6 + rotation * 6 + x]
            continue c <> ord('X')
            offset : y * WIDTH + x
            FIELD[position + offset] = (1 + blockType) * draw

fun canPlace(pos int, rot int) int
    for y := until(4)
        for x := until(4)
            c : shapes[y * 21 * 6 + rot * 6 + x]
            continue c <> ord('X')
            offset : y * WIDTH + x
            if FIELD[pos + offset]
                return 0
    return 1

fun refreshScreen(sdl SDL)
    buff := String.StringBuilder(i8[32])
    # hide cursor, go home
    buff.append('\x1b[?25l\x1b[H\x1b[0m')
    # clear line from cursor right; newline
    buff.append('\x1b[0K\r\n')
    buff.append('  Score: ')
    buff.append(Int.intToString(score))
    buff.append(' High: ')
    buff.append(Int.intToString(highScore))
    buff.append('\x1b[0K\r\n\x1b[0K\r\n')
    for y := until(HEIGHT)
        for x := until(WIDTH)
            c := FIELD[x + WIDTH * y]
            sdl.color(c * 60, c * 60, c * 60, c * 60)
            sdl.fillRect(x * 16, y * 16, 16, 16)
            if c
                c2 : i8[1]
                c2[0] = ord('0') + c - 1
                buff.append('\x1b[4')
                buff.append(c2)
                buff.append('m')
            buff.append('  \x1b[0m')
        buff.append('\x1b[0m\x1b[0K\r\n')
    # Terminal.writeToTerminal(buff.data, buff.len)
    sdl.draw()

WIDTH : 14
HEIGHT : 24
score, highScore, position, rotation, running, blockType := 0
FIELD : i8[WIDTH * HEIGHT]
#      A0123 B0123 C0123 D0123 E0123 F0123 G0123 H0123 I0123 J0123 K0123 L0123 M0123 N0123 O0123 P0123 Q0123 R0123 S0123 T0123 U0123
shapes: ``
        ......       X     X      X    X           X     X     X           X                      XX      X   X      XX         .....
