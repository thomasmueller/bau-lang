type List(T)
    array T[]
    size int

fun newList(T type) List(T)
    return List(T)(T[4])

fun List(T) add(x T)
    if size >= array.len
        n : T[array.len * 2]
        for i := until(array.len)
            n[i] = array[i]
        array = n
    array[size] = x
    size += 1

fun List(T) get(x int) T?
    return array[x]

fun List(T) filter(condition(T) int) macro List(T)
    result : newList(T)
    i := 0
    while i < this.size
        it : this.get(i)
        if condition
            result.add(it)
        i += 1
    return result

fun List(T) map(value T) macro List(T)
    result : newList(T)
    i := 0
    while i < this.size
        it : this.get(i)
        result.add(value)
        i += 1
    return result

fun rangeList(start int, end int) List(int)
    list : newList(int)
    for i := until(end - start)
        list.add(i + start)
    return list

fun range(start int, end int) int[]
    list : int[end - start]
    for i := until(end - start)
        list[i] = i + start
    return list

fun int[] mapInt(value int) macro int[]
    result : int[this.len]
    i := 0
    while i < this.len
        it : this[i]
        result[i] = value
        i += 1
    return result

fun int[] filterInt(condition int) macro int[]
    temp : int[this.len]
    j := 0
    i := 0
    while i < this.len
        it : this[i]
        if condition
            temp[j] = it
            j += 1
        i += 1
    result : int[j]
    i = 0
    while i < j
        result[i] = temp[i]
        i += 1
    return result

fun main()
    list : rangeList(0, 10).filter(it % 2 == 0).map(it * it)
    for i := until(list.size)
        println(i ': ' list.get(i))
    array : range(0, 10).filterInt(it % 2 == 0).mapInt(it * it)
    for i := until(array.len)
        println(i ': ' array[i])

## Expected
0: 0
1: 4
2: 16
3: 36
4: 64
0: 0
1: 4
2: 16
3: 36
4: 64
