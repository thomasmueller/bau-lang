fun test()
    data : i8[10]
    if data.len <= 0
        return
    i := 0 .. data.len
    loop
        data[i]! = i
        next : i + 1
        break next >= data.len
        i = next
    sum := 0
    i = 0
    loop
        sum += data[i]!
        next : i + 1
        break next >= data.len
        i = next
    println(sum)
    
test()

## Expected
45
