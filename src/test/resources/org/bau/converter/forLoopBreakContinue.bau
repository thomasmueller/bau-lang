fun write(d i8[])
    d[0] = 1

fun test(p int, data i8[]) int
    loop p == 0
        if p <= 0
            loop
                write(data)
                break
        if p > 1
            write(data)
        p = 1
    return p

fun range(from int, to int) int
    _ := from
    loop _ < to
        return _
        _ += 1

fun main()
    for a := range(0, 10)
        break a == 5
        continue a == 2
        println(a)
    test(0, i8[2])

## Expected
0
1
3
4
