import org.bau.DateTime
    getNanoTime

fun main()
    expressions: Expression[SIZE]
    statements: Statement[SIZE]
    for i := until(SIZE)
        switch random(i, 9)
        case 0
            v : Variable()
            v.value = 1
            expressions[i] = v
        case 1
            expressions[i] = NumberLiteral()
        case 2
            expressions[i] = StringLiteral()
        case 3
            expressions[i] = NewExpr()
        case 4
            expressions[i] = NullValue()
        case 5
            expressions[i] = ArrayAccess()
        case 6
            expressions[i] = Call()
        case 7
            expressions[i] = Operation()
        case 8
            expressions[i] = Comparison()
        switch random(i32(i + SIZE), 8)
        case 0
            statements[i] = IfStmt()
        case 1
            statements[i] = WhileStmt()
        case 2
            statements[i] = DoWhileStmt()
        case 3
            statements[i] = Assignment()
        case 4
            statements[i] = SwitchStmt()
        case 5
            statements[i] = ReturnStmt()
        case 6
            statements[i] = BreakStmt()
        case 7
            statements[i] = ContinueStmt()
    for test := until(5)
        start := getNanoTime()
        dummy := 0
        for i := until(ITERATIONS)
            dummy += run(expressions, statements)
        time : (getNanoTime() - start) / 1_000_000
        println('Run ' test ': ' time ' ms; dummy: ' dummy)

SIZE: 1_000_000
ITERATIONS: 20

# ===== Traits =====

trait Hashable
    hash() int

trait Expression: Hashable
    eval() int

trait LeftValue: Expression
    store(v int)

trait Statement: Hashable
    execute() int

fun run(expressions Expression[], statements Statement[]) int
    sum := 0
    for i := until(expressions.len)
        e : expressions[i]
        if e
            sum += e.eval()
            sum += e.hash()
        s : statements[i]
        if s
            sum += s.execute()
            sum += s.hash()
    return sum

fun random(x i32, max i32) int
    # https://stackoverflow.com/questions/664014/what-integer-hash-function-are-good-that-accepts-an-integer-hash-key
    ux := x
    ux = ((ux >> 16) ^ ux) * 0x45d9f3b
    ux = ((ux >> 16) ^ ux) * 0x45d9f3b
    ux = (ux >> 16) ^ ux
    if max = 0
        return 0
    # println('result ' ((ux & 0xffffffff) % max))
    return (ux & 0xfffffff) % max

# ===== Expression Implementations =====

type Variable: Expression
    value int

fun Variable hash() int
    return 11

fun Variable eval() int
    return value

fun Variable store(v int)
    value = v

type NumberLiteral: Expression

fun NumberLiteral hash() int
    return 12

fun NumberLiteral eval() int
    return 2

type StringLiteral: Expression

fun StringLiteral hash() int
    return 13

fun StringLiteral eval() int
    return 3

type NewExpr: Expression

fun NewExpr hash() int
    return 14

fun NewExpr eval() int
    return 4

type NullValue: Expression

fun NullValue hash() int
    return 15

fun NullValue eval() int
    return 5

type ArrayAccess: Expression

fun ArrayAccess hash() int
    return 16

fun ArrayAccess eval() int
    return 6

type Call: Expression

fun Call hash() int
    return 17

fun Call eval() int
    return 7

type Operation: Expression

fun Operation hash() int
    return 18

fun Operation eval() int
    return 8

type Comparison: Expression

fun Comparison hash() int
    return 19

fun Comparison eval() int
    return 9

# ===== Statement Implementations =====

type IfStmt: Statement

fun IfStmt hash() int
    return 31

fun IfStmt execute() int
    return 21

type WhileStmt: Statement

fun WhileStmt hash() int
    return 32

fun WhileStmt execute() int
    return 22

type DoWhileStmt: Statement

fun DoWhileStmt hash() int
    return 33

fun DoWhileStmt execute() int
    return 23

type Assignment: Statement, Expression

fun Assignment hash() int
    return 34

fun Assignment execute() int
    return 24
    
fun Assignment eval() int
    return 25
    
type SwitchStmt: Statement

fun SwitchStmt hash() int
    return 36

fun SwitchStmt execute() int
    return 26

type ReturnStmt: Statement

fun ReturnStmt hash() int
    return 37

fun ReturnStmt execute() int
    return 27

type BreakStmt: Statement

fun BreakStmt hash() int
    return 38

fun BreakStmt execute() int
    return 28

type ContinueStmt: Statement

fun ContinueStmt hash() int
    return 39

fun ContinueStmt execute() int
    return 29

