# https://lemire.me/blog/2026/02/15/how-bad-can-python-stop-the-world-pauses-get/

import org.bau.DateTime
    getNanoTime
import org.bau.Int

type Node
    value int
    next  Node?

fun createLinkedList(len int) Node
    head := Node(null)
    current := head
    for i := range(1, len)
        n : Node(null)
        n.value = i
        current.next = n
        current = n
    return head

fun main()
    println('Starting stress test...')
    x := createLinkedList(50_000_000)
    count : 1_000_000
    len : 1000
    worst := 0
    start := getNanoTime()
    last := start
    for i := until(count)
        createLinkedList(len)
        now : getNanoTime()
        worst = Int.max(worst, now - last)
        last = now
    avg : (getNanoTime() - start) / count
    println('Max delay: ' ((worst - avg) / 1_000_000.0) ' ms, avg ' (avg / 1_000_000.0) ' ms; dummy value: ' x.value)
